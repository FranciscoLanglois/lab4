<div class = "conteiner"> 
<table border="1">
  <thead>
    <tr>
      <th>Name</th>
      <th>Species</th>
      <th>Breed</th>
      <th>Date_of_birth</th>
      <th>Weight</th>
      <th>Owner_id</th>
    </tr>
  </thead>
  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td><%= link_to pet.name, pet_path(pet) %></td>
        <td><%= pet.species %></td>
        <td><%= pet.breed %></td>
        <td><%= pet.date_of_birth %></td>
        <td><%= pet.weight %></td>
        <td><%= link_to pet.owner_id, owner_path(pet.owner_id) %></td>
      </tr>
    <% end %>
  </tbody>
</table>