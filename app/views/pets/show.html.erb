<div class="d-flex justify-content-center p-3">
  <div class="btn-group" role="group" aria-label="Navegación Principal">
    <%= link_to "Owners", owners_path, class: "btn btn-primary" %>
    <%= link_to "Pets", pets_path, class: "btn btn-primary" %>
    <%= link_to "Vets", vets_path, class: "btn btn-primary" %>
    <%= link_to "Appointments", appointments_path, class: "btn btn-primary" %>
  </div>
</div>

<div class="d-flex align-items-center gap-3 justify-content-center"> 
<h2><strong>Name:</strong><%= @pet.name %></h1>
<h2><strong>Species:</strong><%= @pet.species %></h1>
<h3><strong>Breed:</strong><%= @pet.breed %></h1>
<h3><strong>Date of Birth:</strong><%= @pet.date_of_birth.strftime("%B %d, %Y") %></h1>
<h3><strong>Weight:</strong><%= @pet.weight %></h1>
<h3><strong>Owner:</strong><%= link_to @pet.owner.first_name, owner_path(@owner)%></h1>

</div>
<div class = "conteiner"> 
<div class="d-flex justify-content-center">
<table class="table table-striped table-hover table-bordered text-center w-75">
  <thead>
    <tr>
      <th>Appointment_ID</th>
      <th>Vet_ID</th>
      <th>Date</th>
      <th>Reason</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% @appointments.each do |appointment| %>
      <tr>
        <td><%= link_to appointment.id, appointment_path(appointment) %></td>
        <td><%= appointment.vet_id %></td>
        <td><%= appointment.date.strftime("%B %d, %Y") %></td>
        <td><%= appointment.reason %></td>
        <td><%= appointment.status %></td>
      </tr>
    <% end %>
  </tbody>
</table>
</div>
</div>