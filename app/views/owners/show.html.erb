<div class = "conteiner"> 
<h1><%= @owner.first_name %></h1>
<h1><%= @owner.last_name %></h1>
<h1><%= @owner.email %></h1>
<h1><%= @owner.phone %></h1>
<h1><%= @owner.address %></h1>
<table border="1">
  <thead>
    <tr>
      <th>Name</th>
      <th>Species</th>
      <th>Breed</th>
      <th>Date_of_birth</th>
      <th>Weight</th>
    </tr>
  </thead>
  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td>
          <%= link_to pet.name, pet_path(pet) %>
        </td>
        <td><%= pet.species %></td>
        <td><%= pet.breed %></td>
        <td><%= pet.date_of_birth %></td>
        <td><%= pet.weight %></td>
      </tr>
    <% end %>
  </tbody>
</table>