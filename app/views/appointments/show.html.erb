<div class="d-flex justify-content-center p-3">
  <div class="btn-group" role="group" aria-label="Navegación Principal">
    <%= link_to "Owners", owners_path, class: "btn btn-primary" %>
    <%= link_to "Pets", pets_path, class: "btn btn-primary" %>
    <%= link_to "Vets", vets_path, class: "btn btn-primary" %>
    <%= link_to "Appointments", appointments_path, class: "btn btn-primary" %>
  </div>
</div>

<div class="d-flex align-items-center gap-3 justify-content-center"> 
<h2><strong>Pet ID:</strong><%= link_to @appointment.pet_id, pet_path(@pet) %></h1>
<h2><strong>Vet ID:</strong><%= link_to @appointment.vet_id, vet_path(@vet) %></h1>
<h3><strong>Date:</strong><%= @appointment.date.strftime("%B %d, %Y") %></h1>
<h3><strong>Reason:</strong><%= @appointment.reason %></h1>
<h3><strong>Status:</strong><%= @appointment.status %></h1>
</div>

<div class = "conteiner"> 
<div class="d-flex justify-content-center">
<table class="table table-striped table-hover table-bordered text-center w-75">
  <thead>
    <tr>
      <th>Name</th>
      <th>Medication</th>
      <th>Dosage</th>
      <th>Notes</th>
      <th>Administered_At</th>
    </tr>
  </thead>
  <tbody>
    <% @treatments.each do |treatment| %>
      <tr>
        <td><%= treatment.name %></td>
        <td><%= treatment.medication %></td>
        <td><%= treatment.dosage %></td>
        <td><%= treatment.notes %></td>
        <td><%= treatment.administered_at %></td>
      </tr>
    <% end %>
  </tbody>
</table>
</div>
</div>